# Copy this file to one named exactly:  .env
# Then paste your real key after the = sign (no quotes, no spaces).
# Get a key: openrouter.ai -> sign in -> Keys -> Create Key (set a $5 limit!)
# NEVER share your .env, screenshot it, or commit it to GitHub.
OPENROUTER_API_KEY=<paste-your-openrouter-key-here>
