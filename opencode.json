{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["openrouter"],
  "model": "openrouter/deepseek/deepseek-v4-flash",
  "small_model": "openrouter/deepseek/deepseek-v4-flash",
  "default_agent": "course-agent",
  "share": "disabled",
  "subagent_depth": 0,
  "provider": {
    "openrouter": {
      "models": {
        "deepseek/deepseek-v4-flash": {
          "options": {
            "provider": {
              "require_parameters": true,
              "zdr": true
            }
          }
        }
      }
    }
  },
  "agent": {
    "course-agent": {
      "description": "Course agent restricted to the fork owner's public work folder",
      "mode": "primary",
      "model": "openrouter/deepseek/deepseek-v4-flash",
      "steps": 20,
      "prompt": "Read AGENTS.md and the current released course material before acting. Cite course answers with repository paths. Edit only the fork owner's student-work folder. Keep the student in control of commits, pushes, and pull requests."
    },
    "build": { "disable": true },
    "plan": { "disable": true },
    "general": { "disable": true },
    "explore": { "disable": true },
    "scout": { "disable": true }
  },
  "permission": {
    "external_directory": "deny",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": {
      "*": "deny",
      "student-work/**": "allow",
      ".course-local/**": "allow"
    },
    "bash": {
      "*": "deny",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch --show-current*": "allow",
      "git remote get-url origin*": "allow",
      "git remote get-url upstream*": "allow",
      "node scripts/init-student.mjs*": "allow",
      "node scripts/start-course-agent.mjs*": "allow",
      "node scripts/validate-local-work.mjs*": "allow",
      "node scripts/commit-work.mjs *": "ask",
      "git push*": "ask",
      "gh auth status*": "allow",
      "gh pr view*": "allow",
      "gh pr create*": "ask"
    },
    "task": "deny",
    "webfetch": "ask",
    "websearch": "allow",
    "skill": "deny"
  }
}
